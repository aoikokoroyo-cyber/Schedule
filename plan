<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>スケジュールメーカー</title>

<style>
*{
  box-sizing:border-box;
  margin:0;
  padding:0;
  font-family:sans-serif;
}

body{
  background:#f5f5f5;
  padding:16px;
}

h1{
  text-align:center;
  margin-bottom:20px;
}

.container{
  display:flex;
  gap:20px;
  flex-wrap:wrap;
}

.cards-panel{
  flex:1;
  min-width:250px;
  background:white;
  padding:15px;
  border-radius:12px;
  box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.schedule-panel{
  flex:2;
  min-width:320px;
  background:white;
  padding:15px;
  border-radius:12px;
  box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.input-row{
  display:flex;
  gap:8px;
  margin-bottom:15px;
}

input{
  flex:1;
  padding:10px;
}

button{
  padding:10px 15px;
  cursor:pointer;
}

.card{
  background:#4f46e5;
  color:white;
  padding:12px;
  border-radius:10px;
  margin-bottom:10px;
  cursor:grab;
  touch-action:none;
}

.slot{
  border:2px dashed #ddd;
  border-radius:10px;
  min-height:70px;
  margin-bottom:10px;
  padding:10px;
}

.slot-header{
  font-weight:bold;
  margin-bottom:8px;
}

.scheduled-card{
  background:#16a34a;
  color:white;
  padding:10px;
  border-radius:8px;
}

@media(max-width:768px){
  .container{
    flex-direction:column;
  }
}
</style>
</head>

<body>

<h1>1日のスケジュールメーカー</h1>

<div class="container">

  <div class="cards-panel">

    <div class="input-row">
      <input id="newCard" placeholder="やりたいこと">
      <button onclick="addCard()">追加</button>
    </div>

    <div id="cards"></div>

  </div>

  <div class="schedule-panel">
    <div id="schedule"></div>
  </div>

</div>

<script>

const HOURS = [];

for(let h=9; h<=21; h++){
  HOURS.push(`${h}:00`);
}

let cards =
JSON.parse(localStorage.getItem("cards")) ||
[
  "読書",
  "英語",
  "散歩",
  "映画"
];

let schedule =
JSON.parse(localStorage.getItem("schedule")) ||
{};

function save(){
  localStorage.setItem("cards",JSON.stringify(cards));
  localStorage.setItem("schedule",JSON.stringify(schedule));
}

function renderCards(){

  const container =
  document.getElementById("cards");

  container.innerHTML="";

  cards.forEach(card=>{

    const div =
    document.createElement("div");

    div.className="card";
    div.draggable=true;
    div.innerHTML=card;

    div.addEventListener("dragstart",e=>{
      e.dataTransfer.setData("text/plain",card);
    });

    container.appendChild(div);

  });
}

function renderSchedule(){

  const scheduleDiv =
  document.getElementById("schedule");

  scheduleDiv.innerHTML="";

  HOURS.forEach(hour=>{

    const slot =
    document.createElement("div");

    slot.className="slot";

    slot.innerHTML=
    `
    <div class="slot-header">${hour}</div>
    `;

    slot.addEventListener("dragover",e=>{
      e.preventDefault();
    });

    slot.addEventListener("drop",e=>{

      e.preventDefault();

      const card =
      e.dataTransfer.getData("text/plain");

      schedule[hour]=card;

      save();
      renderSchedule();

    });

    if(schedule[hour]){

      const card =
      document.createElement("div");

      card.className="scheduled-card";

      card.innerHTML=
      `
      ${schedule[hour]}
      `;

      card.onclick=()=>{

        delete schedule[hour];

        save();
        renderSchedule();

      };

      slot.appendChild(card);
    }

    scheduleDiv.appendChild(slot);

  });

}

function addCard(){

  const input =
  document.getElementById("newCard");

  const value =
  input.value.trim();

  if(!value) return;

  cards.push(value);

  input.value="";

  save();
  renderCards();

}

renderCards();
renderSchedule();

</script>

</body>
</html>
